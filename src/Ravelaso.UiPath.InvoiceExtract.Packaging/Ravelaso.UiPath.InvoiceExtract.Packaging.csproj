<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <TargetFramework>net6.0</TargetFramework>
        <ImplicitUsings>enable</ImplicitUsings>
        <Nullable>enable</Nullable>
        <LangVersion>latest</LangVersion>
        <CheckEolTargetFramework>false</CheckEolTargetFramework>

        <GeneratePackageOnBuild>true</GeneratePackageOnBuild>
        <PackageId>Ravelaso.UiPath.InvoiceExtract</PackageId>
        <PackageIcon>UI_icon.png</PackageIcon>
        <Version>0.0.20</Version>
        <Authors>Ravelaso</Authors>
        <Description>Invoice Extraction framework for .NET / UiPath Studio.</Description>
        <PackageOutputPath>..\nupkgs</PackageOutputPath>
        <IncludeBuildOutput>false</IncludeBuildOutput>
        <NoPackageAnalysis>true</NoPackageAnalysis>
        <ProduceReferenceAssembly>false</ProduceReferenceAssembly>
        <PackageReadmeFile>README.md</PackageReadmeFile>
        <PackageLicenseExpression>MIT</PackageLicenseExpression>
        <PackageProjectUrl>https://github.com/ravelaso/UiPath.InvoiceExtract</PackageProjectUrl>
    </PropertyGroup>

    <ItemGroup>
        <None Include="..\..\README.md" Pack="true" PackagePath="" />
    </ItemGroup>

    <ItemGroup>
        <ProjectReference Include="..\Ravelaso.UiPath.InvoiceExtract.Core\Ravelaso.UiPath.InvoiceExtract.Core.csproj"
                          PrivateAssets="all"
                          ReferenceOutputAssembly="false" />
        <ProjectReference Include="..\Ravelaso.UiPath.InvoiceExtract.Generators\Ravelaso.UiPath.InvoiceExtract.Generators.csproj"
                          PrivateAssets="all"
                          ReferenceOutputAssembly="false" />
    </ItemGroup>

    <ItemGroup>
        <None Include="images\UI_icon.png" Pack="true" PackagePath=""/>
        <None Include="..\Ravelaso.UiPath.InvoiceExtract.Core\bin\$(Configuration)\net6.0\Ravelaso.UiPath.InvoiceExtract.Core.dll"
              Pack="true"
              PackagePath="lib/net6.0" />
        <None Include="..\Ravelaso.UiPath.InvoiceExtract.Generators\bin\$(Configuration)\netstandard2.0\Ravelaso.UiPath.InvoiceExtract.Generators.dll"
              Pack="true"
              PackagePath="analyzers/dotnet/cs" />
    </ItemGroup>

    <ItemGroup>
        <PackageReference Include="PdfPig" Version="0.1.13" />
    </ItemGroup>

</Project>